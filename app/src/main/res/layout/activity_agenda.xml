<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar con botón atrás -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#4CAF50"
        android:paddingStart="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agenda Personal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Contenido scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECCIÓN: Datos Personales -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 DATOS PERSONALES"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <EditText android:id="@+id/etNombre" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombre completo" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etTelefono" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Teléfono" android:inputType="phone" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etDireccion" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Dirección" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etFechaNacimiento" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Fecha de nacimiento" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etGenero" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Género" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/etOcupacion" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Ocupación" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="16dp"/>

            <!-- SECCIÓN: Gustos (10 items) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ MIS GUSTOS (10 items)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginBottom="12dp"/>
            <EditText android:id="@+id/etGusto1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 1" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto2" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 2" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 3" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto4" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 4" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto5" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 5" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto6" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 6" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto7" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 7" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto8" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 8" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto9" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 9" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etGusto10" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Gusto 10" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="16dp"/>

            <!-- SECCIÓN: Preferencias (10 items) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ PREFERENCIAS (10 items)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginBottom="12dp"/>
            <EditText android:id="@+id/etPref1" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 1" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref2" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 2" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref3" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 3" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref4" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 4" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref5" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 5" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref6" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 6" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref7" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 7" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref8" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 8" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref9" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 9" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="5dp"/>
            <EditText android:id="@+id/etPref10" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Preferencia 10" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="16dp"/>

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="💾 GUARDAR CAMBIOS"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>