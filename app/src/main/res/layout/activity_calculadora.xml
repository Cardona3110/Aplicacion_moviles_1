<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar con botón atrás -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#000000"
        android:paddingStart="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"/>
    </LinearLayout>

    <!-- Display area - ocupa el 35% de la pantalla -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="35"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvOperation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#888888"
            android:gravity="end"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="64sp"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:maxLines="1"
            android:adjustViewBounds="true"/>
    </LinearLayout>

    <!-- Botones - ocupa el 65% restante -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="65"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Fila 1: AC  +/-  %  ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="AC"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="#A5A5A5"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btnToggleSign"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="+/-"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="#A5A5A5"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btnPercentage"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="#A5A5A5"
                android:textColor="#000000"/>

            <Button
                android:id="@+id/btnDivide"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="÷"
                android:textSize="24sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9F0A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Fila 2: 7  8  9  × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn7"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="7"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn8"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="8"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn9"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="9"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnMultiply"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="×"
                android:textSize="24sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9F0A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Fila 3: 4  5  6  − -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="4"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="5"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="6"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnSubtract"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="−"
                android:textSize="24sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9F0A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Fila 4: 1  2  3  + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="2"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btn3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="3"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnAdd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="+"
                android:textSize="24sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9F0A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Fila 5: 0 (doble ancho)  .  = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_marginEnd="8dp"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"/>

            <Button
                android:id="@+id/btnDecimal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text=","
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnEquals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="="
                android:textSize="24sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9F0A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>